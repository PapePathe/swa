oluasusu:igbo;

// ------------------------------------
// PARTITION FUNCTION (Helper for QuickSort)
// Rearranges the array elements around a pivot.
// Returns the index of the pivot element.
// ------------------------------------
oru partition(list: [5]onuogugu, low: onuogugu, high: onuogugu) onuogugu {
  ka pivot: onuogugu = list[high]; // Choose the rightmost element as the pivot
  ka i: onuogugu = low - 1;        // Index of smaller element
  ka j: onuogugu = low;
  
  // Custom temporary variable for swapping (SWA doesn't show multiple assignment)
  ka temp: onuogugu = 0; 

  dika(j < high) {
    oburu(list[j] < pivot) {
      i = i + 1;
      
      // SWAP: list[i] and list[j]
      temp = list[i];
      list[i] = list[j];
      list[j] = temp;
    }
    j = j + 1;
  }
  
  // SWAP: list[i+1] and pivot (list[high])
  temp = list[i + 1];
  list[i + 1] = list[high];
  list[high] = temp;

  weghachi i + 1; // Return the partitioning index
}

// ------------------------------------
// QUICKSORT FUNCTION (Recursive Sorting)
// ------------------------------------
oru quickSort(list: [5]onuogugu, low: onuogugu, high: onuogugu) onuogugu {
  ka pi: onuogugu = 0;

  oburu(low < high) {
    // pi is the partitioning index, list[pi] is now in the correct place
    pi = partition(list, low, high);

 //   // Recursively sort elements before and after partition
    quickSort(list, low, pi - 1);
    quickSort(list, pi + 1, high);
  }
  
  weghachi 0; // Return the modified array
}


mbido () onuogugu {
  // Array to sort: 
  ka unsorted_list: [5]onuogugu = [5]onuogugu{5, 4, 3, 2, 1};
  ka idx: onuogugu = 0;
  
  quickSort(unsorted_list, 0, 4); 

  deputa("Sorted List: ");
  dika(idx < 5) {
    deputa("%d ", unsorted_list[idx]);
    idx = idx + 1;
  }
  
  weghachi 0; 
}
