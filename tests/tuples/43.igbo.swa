oluasusu:igbo;

oru two()(onuogugu, onuogugu) { weghachi 2, 3; }
// Test 44: Tuple assignment with pointer dereference (if pointers exist)
nhazi Node { val: onuogugu, next: *Node, }
mbido() onuogugu {
  ka n: Node = Node{val: 0, next: 0};
  (n.val, n.next.val) = two(); // n.next is nil -> runtime error
  weghachi 0;
}
