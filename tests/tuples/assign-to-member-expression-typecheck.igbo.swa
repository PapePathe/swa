oluasusu:igbo;

oru divmod(a: onuogugu, b: onuogugu) (onuogugu, onuogugu, njehie) {
    oburu (b == 0) {
        weghachi 0, 0, njehie("dividend is zero"); 
    }

    ka div : onuogugu = a / b;
    ka mod: onuogugu = a % b;

    weghachi div, mod, efu(njehie); 
}

nhazi Result {
  div: onuogugu,
  mod: onuogugu,
}

mbido() onuogugu {
  ka p : Result;
  ka err: njehie;
  ka div : onuogugu;
  ka mod: onuogugu;
   (err, p.div, p.mod) = divmod(100, 23);

  oburu(err != efu(njehie)) {
    deputa("Division by zero error (%s)", err);
    weghachi -1;
  }

   deputa("p.div = %d, p.mod = %d", p.div, p.mod);

  weghachi 0;
}
