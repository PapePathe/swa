dialect:english;

// Rule 110: known to be Turing complete.
// Rule 110 transitions:
// 111 -> 0
// 110 -> 1
// 101 -> 1
// 100 -> 0
// 011 -> 1
// 010 -> 1
// 001 -> 1
// 000 -> 0

func get_next_state(left: int, mid: int, right: int) int {
    if (left == 1) {
        if (mid == 1) {
            if (right == 1) { return 0; }
            return 1;
        }
        if (mid == 0) {
            if (right == 1) { return 1; }
            return 0;
        }
    }
    if (left == 0) {
        if (mid == 1) {
            if (right == 1) { return 1; }
            return 1;
        }
        if (mid == 0) {
            if (right == 1) { return 1; }
            return 0;
        }
    }
    return 0;
}

start() int {
    print("Rule 110 Cellular Automaton (Generation 0-20)\n");
    
    // Tape size 30
    let TAPE_SIZE: int = 30;
    let tape: [30]int = [30]int{}; // Initialize with zeros
    
    // Initial state: 1 at the right end
    tape[29] = 1;
    
    let gen: int = 0;
    while (gen < 20) {
        // Print current generation
        let p: int = 0;
        while (p < TAPE_SIZE) {
            if (tape[p] == 1) {
                print("#");
            } else {
                print(".");
            }
            p = p + 1;
        }
        print("\n");
        
        // Compute next state
        let next_tape: [30]int = [30]int{};
        let i: int = 0;
        while (i < TAPE_SIZE) {
            let left: int = 0;
            let mid: int = tape[i];
            let right: int = 0;
            
            if (i > 0) { left = tape[i-1]; }
            if (i < TAPE_SIZE - 1) { right = tape[i+1]; }
            
            next_tape[i] = get_next_state(left, mid, right);
            i = i + 1;
        }
        
        // Update tape
        let u: int = 0;
        while (u < TAPE_SIZE) {
            tape[u] = next_tape[u];
            u = u + 1;
        }
        
        gen = gen + 1;
    }
    
    return 0;
}
