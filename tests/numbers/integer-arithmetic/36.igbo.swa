oluasusu:igbo;

// Test 38: Expression with all operators and signed numbers
mbido() onuogugu {
  ka a: onuogugu = -2 * 3 + 4 / -2 - (-5) % 3;
  // -2*3 = -6, 4/-2 = -2, (-5)%3 = -2 (typical), then -6 + (-2) = -8, -8 - (-2) = -6
  deputa("-2 * 3 + 4 / -2 - (-5) %% 3 = %d", a); // Expected: -6
  weghachi 0;
}
