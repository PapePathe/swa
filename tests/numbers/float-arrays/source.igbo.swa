oluasusu:igbo;

mbido() onuogugu {
  ka numbers: [3]ofe = [3]ofe{1.1, 2.2, 3.3};

  oburu(numbers[0] == 1.1) {
    deputa("%s", "ok");
  } maobu {
    deputa("%s", "Float array access [0] failed");
  }

  oburu(numbers[1] == 2.2) {
    deputa("%s", "ok");
  } maobu {
    deputa("%s", "Float array access [1] failed");
  }

  oburu(numbers[2] == 3.3) {
    deputa("%s", "ok");
  } maobu {
    deputa("%s", "Float array access [2] failed");
  }

  weghachi 0;
}
