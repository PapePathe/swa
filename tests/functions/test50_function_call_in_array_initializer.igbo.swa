oluasusu:igbo;

// Test 50: Function call in array initializer
oru gen(i: onuogugu) onuogugu {
  weghachi i * i;
}
mbido() onuogugu {
  ka arr: [5]onuogugu = [5]onuogugu{gen(0), gen(1), gen(2), gen(3), gen(4)};
  ka i: onuogugu = 0;
  dika (i < 5) {
    deputa("arr[%d] = %d\n", i, arr[i]);
    i = i + 1;
  }
  // Expected: 0,1,4,9,16
  weghachi 0;
}
