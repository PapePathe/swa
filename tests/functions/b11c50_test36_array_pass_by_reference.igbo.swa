oluasusu:igbo;

// Test 36: Function that modifies array elements (array passed by reference?)
oru modifyArray(arr: [5]onuogugu) onuogugu {
  arr[0] = 999;
  weghachi 0;
}
mbido() onuogugu {
  ka a: [5]onuogugu = [5]onuogugu{1,2,3,4,5};
  modifyArray(a);
  deputa("a[0] = %d", a[0]);
  weghachi 0;
}
