oluasusu:igbo;

oru sum(list: [5]onuogugu) onuogugu {
  ka ret : onuogugu = 0;
  ka idx: onuogugu = 0;
  
  dika(idx < 5) {
    ret = ret + list[idx];
    idx = idx + 1;
  }

  weghachi ret;
}

oru sumf(list: [5]ofe) ofe {
  ka ret: ofe = 0.0;
  ka idx: onuogugu = 0;
  
  dika(idx < 5) {
    ret = ret + list[idx];
    idx = idx + 1;
  }

  weghachi ret;
}

mbido () onuogugu {
  ka list: [5]onuogugu = [5]onuogugu{ 1, 2, 3, 4 , 5};
  ka listf: [5]ofe = [5]ofe{ 1.00, 2.000, 3.000, 4.0 , 5.000000};
  ka sum_of_list: onuogugu = sum(list);
  ka sum_of_listf: ofe = sumf(listf);

  deputa("sum: %d, sumf: %.2f", sum_of_list, sum_of_listf);

  weghachi 0; 
}
