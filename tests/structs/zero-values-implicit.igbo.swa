oluasusu:igbo;

nhazi Dimensions {
  Length: ofe,
  Width:  ofe,
  Height: onuogugu,
  Name:   ederede,
}

nhazi Object {
  Dim:   Dimensions,
  Shape: ederede,
}

nhazi Block {
  top:    Object,
  bottom: Object,
}

mbido() onuogugu {
  ka dim : Dimensions;
  deputa("- Dimension with zero value\n");
  deputa(
    "Length: %.2f, Width: %.2f, Height: %d, Name: %s\n\n", 
    dim.Length, dim.Width, dim.Height, dim.Name,
  );

  ka obj : Object;
  deputa("- Object with zero value\n");
  deputa(
    "Length: %.2f, Width: %.2f, Height: %d, Name: %s, Shape: %s\n\n", 
    obj.Dim.Length, obj.Dim.Width, obj.Dim.Height, obj.Dim.Name, obj.Shape,
  );

  ka block : Block;
  deputa("- Block with zero value\n");
  deputa(
    "Top(Length: %.2f, Width: %.2f, Height: %d, Name: %s, Shape: %s)\n", 
    block.top.Dim.Length, block.top.Dim.Width, block.top.Dim.Height, 
    block.top.Dim.Name, block.top.Shape,
  );
  deputa(
    "Bottom(Length: %.2f, Width: %.2f, Height: %d, Name: %s, Shape: %s)\n", 
    block.bottom.Dim.Length, block.bottom.Dim.Width, block.bottom.Dim.Height, 
    block.bottom.Dim.Name, block.bottom.Shape,
  );

  weghachi 0;
}
